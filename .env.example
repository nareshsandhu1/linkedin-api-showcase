# LinkedIn Developer App credentials (Auth tab of https://www.linkedin.com/developers/apps)
LINKEDIN_CLIENT_ID=your-client-id-here
LINKEDIN_CLIENT_SECRET=your-client-secret-here

# Must EXACTLY match a redirect URL registered in your LinkedIn app's Auth tab.
LINKEDIN_REDIRECT_URI=http://localhost:3000/auth/linkedin/callback

# Space-delimited OAuth scopes. Defaults below use "Sign In with LinkedIn using OpenID Connect" product.
# Other examples: "r_liteprofile r_emailaddress w_member_social"
LINKEDIN_SCOPES=openid profile email

# Random string used to sign the session cookie.
SESSION_SECRET=replace-with-a-long-random-string

PORT=3000
